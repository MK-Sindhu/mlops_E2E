{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 30,
  "version": 1,
  "uid": "fraud-detection-ml-ops",
  "title": "Fraud Detection — ML Ops & Feedback Loop",
  "tags": ["fraud", "ml-ops", "feedback", "drift"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Predictions per minute (legit vs fraud)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "rate(predictions_total[1m]) * 60",
         "legendFormat": "{{result}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short",
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "stacking": {"mode": "normal"}},
          "color": {"mode": "palette-classic"}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"]}}
    },
    {
      "id": 2,
      "title": "Fraud ratio over time",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "fraud_ratio", "legendFormat": "fraud ratio", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "red", "value": 0.10}]},
          "custom": {"thresholdsStyle": {"mode": "line"}}}
      }
    },
    {
      "id": 3,
      "title": "Real-world model accuracy (rolling, from feedback)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "model_real_accuracy", "legendFormat": "accuracy", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.85}]},
          "custom": {"thresholdsStyle": {"mode": "line+area"}}}
      }
    },
    {
      "id": 4,
      "title": "Feedback received per minute (by actual label)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "rate(feedback_total[5m]) * 60",
         "legendFormat": "actual_label={{actual_label}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short",
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}},
          "color": {"mode": "palette-classic"}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}}
    },
    {
      "id": 5,
      "title": "Total predictions",
      "type": "stat",
      "gridPos": {"x": 0, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [{"expr": "sum(predictions_total) OR on() vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 6,
      "title": "Total feedback",
      "type": "stat",
      "gridPos": {"x": 4, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [{"expr": "sum(feedback_total) OR on() vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 7,
      "title": "Feedback / prediction ratio",
      "type": "stat",
      "gridPos": {"x": 8, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "(sum(feedback_total) OR on() vector(0)) / clamp_min(sum(predictions_total), 1)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "green", "value": 0.20}]}}
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "value_and_name"}
    },
    {
      "id": 8,
      "title": "Fraud rate (snapshot)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [{"expr": "fraud_ratio", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "red", "value": 0.10}]}}
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "value_and_name"}
    },
    {
      "id": 9,
      "title": "Real-world accuracy (snapshot)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [{"expr": "model_real_accuracy", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.85}]}}
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "value_and_name"}
    },
    {
      "id": 10,
      "title": "Inference latency p99",
      "type": "stat",
      "gridPos": {"x": 20, "y": 16, "w": 4, "h": 5},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.99, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.1},
            {"color": "red", "value": 0.2}]}}
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "value_and_name"}
    },
    {
      "id": 11,
      "title": "Cumulative predictions vs cumulative feedback",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 21, "w": 24, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(predictions_total)", "legendFormat": "predictions", "refId": "A"},
        {"expr": "sum(feedback_total)",    "legendFormat": "feedback",    "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short",
          "custom": {"drawStyle": "line", "fillOpacity": 15}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}}
    },
    {
      "id": 12,
      "title": "Operational links",
      "type": "text",
      "gridPos": {"x": 0, "y": 29, "w": 24, "h": 4},
      "options": {
        "mode": "markdown",
        "content": "**MLflow Tracking + Registry** — http://localhost:5000  \n**Airflow DAGs (`fraud_retraining_check`, `fraud_stats_scrape`)** — http://localhost:8090  \n**Trigger an immediate retraining check** — `docker compose exec airflow airflow dags trigger fraud_retraining_check`  \n**Promote a model to Production** — `python scripts/promote_model.py --version <N> --alias production`"
      }
    }
  ]
}
