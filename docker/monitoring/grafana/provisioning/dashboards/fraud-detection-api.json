{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 30,
  "version": 1,
  "uid": "fraud-detection-api",
  "title": "Fraud Detection — API",
  "tags": ["fraud", "api"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Prediction rate (req/s) by result",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(predictions_total[1m])",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Inference latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.2}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 3,
      "title": "Fraud ratio (rolling)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "fraud_ratio", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.20}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Real-world model accuracy (from feedback)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "model_real_accuracy", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "green", "value": 0.85}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Total predictions",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(predictions_total)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Feedback received",
      "type": "stat",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(feedback_total)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "HTTP request rate by handler (FastAPI instrumentator)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right"}
      }
    }
  ]
}
