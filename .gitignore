# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual Environment
venv/
.venv/
.env

# Data (tracked by DVC)
data/raw/*.csv
data/processed/*.csv
data/processed/*.joblib

# Models (tracked by DVC)
models/*.joblib
models/best_model.json
models/feature_names.json
models/backup/

# MLflow
mlruns/

# Encryption keys (NEVER commit)
configs/.encryption_key

# Docker secrets — real values live here, never committed.
# secrets.example/ holds placeholder files that ARE committed.
secrets/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Runtime artifacts
*.db
data/*.db
dvc_plots/

# Scraped external data (regenerated, content-dependent on scrape time)
data/external/

# Experiment comparison output (regenerated by scripts/run_experiments.py)
reports/experiment_comparison.json

# Notebook checkpoints
.ipynb_checkpoints/

# pytest-cov outputs
.coverage
coverage.xml
htmlcov/
